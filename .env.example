# Telegram Bot Configuration
# Get token from Telegram @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID (the bot can tell you this when you send /start, or use a tool to look it up)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# AI API Configuration (Gemini or OpenRouter)
# For Gemini: get key from Google AI Studio (https://aistudio.google.com/) and use models like gemini-2.5-flash
# For OpenRouter (supports GPT-4o, Claude, etc.): get key from https://openrouter.ai and use models like google/gemini-2.5-flash or anthropic/claude-3.5-sonnet
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Reasoning effort for deep thinking models (options: none, low, medium, high)
REASONING_EFFORT=none

# Global Hotkey (uses pynput format)
# Examples: <ctrl>+<f1>, <ctrl>+<shift>+<f12>
HOTKEY=<ctrl>+<f1>
